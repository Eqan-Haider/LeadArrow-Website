// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  REP
}

enum LeadSource {
  CRM
  SLACK
}

enum LeadStatus {
  PENDING
  CLAIMED
  MISSED
}

model Workspace {
  id                   String   @id @default(uuid())
  name                 String
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users                User[]
  leads                Lead[]
  licenseKeys          LicenseKey[]
  subscriptionLicenses SubscriptionLicense[]
  crmConnections       CRMConnection[]

  @@map("workspaces")
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  phoneNumber String?
  password    String
  fullName    String
  companyName String  @default("")

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  companyId String?
  role      Role    @default(REP)

  isActive    Boolean @default(true)
  isAvailable Boolean @default(true)
  pairingCode String?

  refreshTokenHash String?
  tokenVersion     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claimedLeads      Lead[]                @relation("ClaimedLeads")
  routingAttempts   RoutingAttempt[]
  availabilitySlots RepAvailabilitySlot[]

  @@map("users")
}

model Lead {
  id         String     @id @default(uuid())
  name       String
  email      String?
  phone      String?
  source     LeadSource @default(SLACK)
  status     LeadStatus @default(PENDING)
  rawPayload String? // original Slack text for audit

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  claimedBy String?
  claimer   User?   @relation("ClaimedLeads", fields: [claimedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model Company {
  id                String   @id @default(uuid())
  name              String
  routingMethod     String   @default("ROUND_ROBIN")
  roundRobinPointer Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  licenseKeys LicenseKey[]
  leadLogs    LeadLog[]
}

model LicenseKey {
  id              String    @id @default(uuid())
  keyString       String    @unique
  plan            String?
  email           String?
  companyName     String?
  isRedeemed      Boolean   @default(false)
  redeemedByEmail String?
  redeemedAt      DateTime?
  stripeSessionId String?
  isActive        Boolean   @default(true)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadLog {
  id           String  @id @default(uuid())
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])
  prospectName String
  leadSource   String
  crmLeadId    String?
  crmRecordUrl String?
  status       String  @default("ROUTING")

  firstAlertedAt  DateTime?
  firstAnsweredAt DateTime?
  acceptedAt      DateTime?
  acceptedVia     String?
  source          String?

  createdAt DateTime         @default(now())
  attempts  RoutingAttempt[]

  @@map("lead_logs")
}

model RoutingAttempt {
  id           String  @id @default(uuid())
  leadLogId    String
  leadLog      LeadLog @relation(fields: [leadLogId], references: [id])
  userId       String?
  user         User?   @relation(fields: [userId], references: [id])
  attemptOrder Int
  status       String  @default("RINGING")

  callControlId String?
  callStartAt   DateTime?
  answerAt      DateTime?
  acceptedAt    DateTime?
  channel       String?

  createdAt DateTime @default(now())

  @@map("routing_attempts")
}

model RepAvailabilitySlot {
  id        String @id @default(uuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String @default("America/New_York")

  @@map("rep_availability_slots")
}

model SubscriptionLicense {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  licenseToken  String    @unique
  plan          String
  status        String    @default("PREMIUM")
  issuedToEmail String
  issuedToName  String?
  activatedAt   DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("subscription_licenses")
}

model CRMConnection {
  id           String    @id @default(uuid())
  workspaceId  String    @unique
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  provider     String    @default("close")
  accessToken  String
  refreshToken String?
  tokenType    String    @default("Bearer")
  expiresAt    DateTime?
  crmUserId    String?
  crmEmail     String?
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("crm_connections")
}
