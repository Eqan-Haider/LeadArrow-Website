{
  "manifest_version": 3,
  "name": "LeadArrow Agent Comm Node",
  "version": "1.0.0",
  "description": "Live telephony dialer, call radar, and stream synchronizer for LeadArrow dashboard.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5001/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeadArrow Agent Comm Node",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
